{
  "name": "@qookie/vue",
  "version": "0.1.0",
  "description": "Vue 3 components and composable for Qookie cookie consent — works in Astro, Vite+Vue and Nuxt.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tochukwu19/qookie-nuxt.git",
    "directory": "packages/vue"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": [
    "**/*.vue",
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    }
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "unbuild",
    "test": "vitest run"
  },
  "dependencies": {
    "@qookie/core": "workspace:*"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@vitejs/plugin-vue": "^6.0.0",
    "@vitest/coverage-v8": "^3.2.0",
    "@vue/test-utils": "^2.4.0",
    "jsdom": "^29.1.1",
    "typescript": "^5.6.0",
    "unbuild": "^3.0.0",
    "vitest": "^3.2.0",
    "vue": "^3.5.33",
    "vue-tsc": "^3.2.8"
  },
  "license": "MIT"
}
