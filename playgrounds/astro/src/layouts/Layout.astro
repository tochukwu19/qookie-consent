---
import { QookieBanner } from '@qookie/vue'
const { title = 'Qookie × Astro' } = Astro.props
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <!-- Font is a Nuxt-only convenience; in Astro you wire it yourself. -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600&display=swap"
    />
    <style is:global>
      :root {
        --qookie-font: 'Poppins', sans-serif;
        --qookie-accent: #226845;
        --qookie-accent-fg: #ffffff;
      }
      body {
        font-family: var(--qookie-font);
        margin: 0;
        padding: 2rem clamp(1rem, 5vw, 4rem);
        color: #111827;
        line-height: 1.6;
      }
      a { color: var(--qookie-accent); }
    </style>
  </head>
  <body>
    <slot />
    <!-- Single banner island; its modal is shared across the app. -->
    <QookieBanner client:load />
  </body>
</html>
